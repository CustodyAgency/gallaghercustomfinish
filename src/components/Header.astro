---
const pathname = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/painting-contractor-syracuse-ny/', label: 'About' },
  { href: '/interior-exterior-painting-services-syracuse-ny/', label: 'Services' },
  { href: '/painting-portfolio-syracuse-central-new-york/', label: 'Portfolio' },
  { href: '/customer-reviews-syracuse-ny-gallagher-custom-finish/', label: 'Reviews' },
  { href: '/free-painting-estimate-syracuse-cortland-ny/', label: 'Contact' },
  { href: '/paint-cost-estimator-syracuse-ny/', label: 'Estimator' }
];

// Determine if we're on a page with a dark background hero to adjust initial contrast
// For Home, About, form pages, the hero is dark where header starts transparent
const isDarkHero = ['/', '/painting-contractor-syracuse-ny/', '/free-painting-estimate-syracuse-cortland-ny/'].includes(pathname.replace(/\/$/, '') + '/');

const initialTextColor = isDarkHero ? "text-cream" : "text-charcoal";
---

<header id="site-header" class={`fixed top-0 left-0 right-0 z-40 transition-colors duration-300 bg-transparent py-4 text-cream`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
    <!-- Logo Container -->
    <div class="flex-1 lg:flex justify-start items-center hidden">
      <a href="/" class="flex items-center gap-3 group focus-visible:outline-brass hover:text-brass transition-colors z-[60]">
        <!-- Desktop Text Logo -->
        <div class="flex items-center gap-3">
          <span class="font-heading font-bold text-2xl text-brass">GCF</span>
          <span class="font-heading text-lg">Gallagher Custom Finish</span>
        </div>
      </a>
    </div>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex flex-2 justify-center items-center gap-6" aria-label="Main Navigation">
      {navLinks.slice(0, 5).map((link) => (
        <a 
          href={link.href} 
          class:list={[
            "text-base font-medium transition-colors hover:text-brass",
            { "text-brass underline decoration-2 underline-offset-4": pathname === link.href || pathname === link.href.replace(/\/$/, '') }
          ]}
          aria-current={pathname === link.href || pathname === link.href.replace(/\/$/, '') ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Header CTA & Mobile Toggle -->
    <div class="flex-1 lg:flex-none flex flex-nowrap justify-end items-center gap-1.5 md:gap-4 z-[60]">
      <a href="tel:3156077246" class="lg:hidden flex items-center justify-center bg-brass text-charcoal px-3 py-2 rounded font-bold text-sm shadow-sm focus-visible:outline-cream whitespace-nowrap">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        CALL
      </a>
      <a href="tel:3156077246" class="hidden xl:inline-block font-body font-bold text-2xl tracking-wide hover:text-brass transition-colors mr-2 whitespace-nowrap">315-607-PAINT</a>
      <a href="/free-painting-estimate-syracuse-cortland-ny/" class="hidden md:inline-block bg-brass text-charcoal px-5 py-2.5 font-bold hover:bg-cream transition-colors text-base rounded shadow-sm whitespace-nowrap">
        Free Estimate
      </a>
      <button 
        id="mobile-menu-toggle" 
        class="lg:hidden p-2 hover:text-brass focus-visible:outline-brass ml-1 md:ml-2"
        aria-expanded="false" 
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 drop-shadow-md" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div 
    id="mobile-menu" 
    class="fixed inset-0 bg-charcoal text-cream z-50 transform translate-x-full transition-transform duration-300 flex flex-col lg:hidden"
    aria-hidden="true"
  >
    <div class="p-4 flex justify-between items-center border-b border-gray-700">
      <span class="font-heading font-bold text-xl text-brass">GCF</span>
      <button 
        id="mobile-menu-close" 
        class="p-2 text-cream hover:text-brass focus-visible:outline-brass"
        aria-label="Close menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <nav class="flex-1 flex flex-col py-8 px-6 gap-6 overflow-y-auto" aria-label="Mobile Navigation">
      {navLinks.map((link) => (
        <a 
          href={link.href} 
          class="text-2xl font-heading text-cream hover:text-brass transition-colors"
          aria-current={pathname === link.href || pathname === link.href.replace(/\/$/, '') ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
      <div class="mt-auto mb-4 space-y-4">
        <a href="tel:3156077246" class="flex items-center justify-center gap-3 border-2 border-brass text-cream block text-center py-4 font-body font-bold text-2xl tracking-wide hover:bg-brass hover:text-charcoal transition-colors rounded">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call 315-607-PAINT
        </a>
        <a href="/free-painting-estimate-syracuse-cortland-ny/" class="bg-brass text-charcoal block text-center py-4 font-bold text-xl hover:bg-cream transition-colors rounded">
          Get a Free Estimate
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileClose = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  // Determine if it starts over dark bg
  const alwaysDarkText = document.body.dataset.headerStyle === 'light'; // wait, didn't pass this prop yet. We'll default to light text over full hero backgrounds, but switch on scroll.

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.remove('bg-transparent', 'py-4', 'text-charcoal');
      header?.classList.add('bg-charcoal/90', 'backdrop-blur-md', 'py-2', 'shadow-md', 'text-cream');
    } else {
      header?.classList.add('bg-transparent', 'py-4');
      header?.classList.remove('bg-charcoal/90', 'backdrop-blur-md', 'py-2', 'shadow-md');
      // If we are at top and it was supposed to be text-charcoal, we should revert
      if(window.location.pathname.includes('services') || window.location.pathname.includes('portfolio') || window.location.pathname.includes('reviews')){
         // For pages without dark hero, maybe they need different logic if no hero image is present
      }
    }
  });

  // Init scroll check in case page loaded half way down
  if (window.scrollY > 50) {
      header?.classList.remove('bg-transparent', 'py-4');
      header?.classList.add('bg-charcoal/90', 'backdrop-blur-md', 'py-2', 'shadow-md', 'text-cream');
  }

  function openMenu() {
    mobileMenu?.classList.remove('translate-x-full');
    mobileToggle?.setAttribute('aria-expanded', 'true');
    mobileMenu?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    mobileClose?.focus();
  }

  function closeMenu() {
    mobileMenu?.classList.add('translate-x-full');
    mobileToggle?.setAttribute('aria-expanded', 'false');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    mobileToggle?.focus();
  }

  mobileToggle?.addEventListener('click', openMenu);
  mobileClose?.addEventListener('click', closeMenu);
</script>
