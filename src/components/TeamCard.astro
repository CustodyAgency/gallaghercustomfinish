---
export interface Props {
  imagePath: string;
  name: string;
  role: string;
  quote: string;
}

const { imagePath, name, role, quote } = Astro.props;
---
<div class="flex flex-col md:flex-row gap-8 items-center bg-white p-8 sm:p-10 shadow-sm border border-gray-100 rounded-sm">
  <div class="w-48 h-48 md:w-56 md:h-56 shrink-0 relative">
    <div class="absolute inset-0 bg-brass/20 translate-x-3 translate-y-3 border border-brass/40 rounded-sm pointer-events-none"></div>
    <img 
      src={imagePath} 
      alt={name} 
      width="224" 
      height="224" 
      class="w-full h-full object-cover filter grayscale hover:grayscale-0 transition-all duration-500 rounded-sm relative z-10 block"
    />
  </div>
  
  <div class="flex flex-col mt-4 md:mt-0">
    <svg class="text-brass w-12 h-12 mb-4 opacity-50" fill="currentColor" viewBox="0 0 32 32" aria-hidden="true">
      <path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm16.512 0c-4.8 3.456-8.256 9.12-8.256 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4z" />
    </svg>
    <blockquote class="text-xl sm:text-2xl font-heading italic text-charcoal leading-relaxed mb-6">
      "{quote}"
    </blockquote>
    <div>
      <p class="font-bold text-lg text-charcoal">{name}</p>
      <p class="text-brass font-semibold text-base uppercase tracking-wider mt-1">{role}</p>
    </div>
  </div>
</div>
