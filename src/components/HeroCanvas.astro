---
---
<div id="canvas-container" class="absolute inset-0 z-0 pointer-events-none overflow-hidden bg-charcoal">
  <!-- The base image that will get painted over -->
  <img 
    src="/images/interior-painting-contractor-syracuse-ny-gallagher-custom-finish.jpg" 
    alt="Interior painting contractor" 
    class="absolute inset-0 w-full h-full object-cover" 
  />
  
  <!-- The canvas where the teal paint strokes will be drawn -->
  <canvas id="hero-canvas" class="absolute inset-0 w-full h-full" aria-hidden="true" aria-label="Animated paint texture, decorative"></canvas>
  
  <!-- Protective gradient to ensure text legibility always -->
  <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/50 to-transparent pointer-events-none z-10"></div>
</div>

<script>
  class PaintRollerCanvas {
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private width: number = 0;
    private height: number = 0;
    private rafId: number = 0;
    private isVisible: boolean = true;
    
    // Custom Teal Color
    private paintColor = '#4a8f96';
    
    // Animation state
    private startTime: number = 0;
    private animationDuration: number = 10000; // 10 seconds total
    
    // Pre-calculated stroke paths
    private strokes: Array<{
      startX: number,
      startY: number,
      endX: number,
      endY: number,
      width: number,
      delay: number, // percentage of total duration when it starts
      duration: number // percentage of total duration it takes to finish
    }> = [];

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      const context = canvas.getContext('2d', { alpha: true });
      if (!context) return;
      this.ctx = context;
      
      this.init();
      this.bindEvents();
      
      // Start animation
      this.startTime = performance.now();
      this.animate();
    }

    private init() {
      this.resize();
      this.generateStrokes();
    }

    private resize() {
      this.width = window.innerWidth;
      this.height = window.innerHeight;
      
      // Handle high-DPI displays safely
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      this.canvas.width = this.width * dpr;
      this.canvas.height = this.height * dpr;
      
      this.ctx.scale(dpr, dpr);
      
      // If we resize, recalculate strokes to fit new dimensions
      this.generateStrokes();
    }

    private generateStrokes() {
      this.strokes = [];
      const numStrokes = Math.ceil(this.width / 80) + 4; // Much higher density to guarantee coverage
      const strokeWidthMax = 350;
      const strokeWidthMin = 250;
      
      // We want them to overlap heavily and go top to bottom
      for (let i = 0; i < numStrokes; i++) {
        // Base X position distributed across screen width
        const baseX = (this.width / numStrokes) * i;
        
        // Add some randomness to x position
        const offsetX = (Math.random() - 0.5) * 50; // Tighter offset
        const x = baseX + offsetX;
        
        // Randomize direction slightly (mostly vertical)
        const angle = (Math.random() - 0.5) * 0.2; // slight tilt
        
        const strokeLength = this.height * 1.5; // ensure it covers top to bottom
        
        // Stagger the start times so they don't all paint at once
        // For example, start scattered between 0% and 50% of the duration
        const delay = Math.random() * 0.5;
        
        // Each stroke takes between 30% and 50% of the total time to finish
        const duration = 0.3 + (Math.random() * 0.2);

        this.strokes.push({
          startX: x,
          startY: -200, // start above screen
          endX: x + Math.sin(angle) * strokeLength,
          endY: this.height + 200, // end below screen
          width: strokeWidthMin + Math.random() * (strokeWidthMax - strokeWidthMin),
          delay: delay,
          duration: duration
        });
      }
      
      // Sort strokes by delay so we draw the earliest ones first (layering)
      this.strokes.sort((a, b) => a.delay - b.delay);
    }

    private bindEvents() {
      window.addEventListener('resize', () => {
        this.resize();
        // Force a redraw when resizing by resetting the start time slightly back 
        // to prevent jarring flashes, though keeping it simple is best.
        this.startTime = performance.now(); 
      });
      
      document.addEventListener('visibilitychange', () => {
        this.isVisible = !document.hidden;
        if (this.isVisible) {
          this.startTime = performance.now() - (this.animationDuration); // Pause effect basically
          // Note: Full pause implementation requires tracking elapsed time.
          // For a simple paint reveal, just letting it finish or static is fine.
          this.animate();
        } else {
          cancelAnimationFrame(this.rafId);
        }
      });
    }

    private drawStroke(stroke: any, progress: number) {
      if (progress <= 0) return;
      
      // Calculate how far along the path this stroke should be (0 to 1)
      const t = Math.min(1, progress); 
      
      // Current position
      const currentX = stroke.startX + (stroke.endX - stroke.startX) * t;
      const currentY = stroke.startY + (stroke.endY - stroke.startY) * t;

      this.ctx.beginPath();
      this.ctx.moveTo(stroke.startX, stroke.startY);
      this.ctx.lineTo(currentX, currentY);
      
      this.ctx.lineWidth = stroke.width;
      this.ctx.lineCap = 'round';
      this.ctx.lineJoin = 'round';
      
      // Solid teal color
      this.ctx.strokeStyle = this.paintColor;
      
      // Draw it
      this.ctx.stroke();
      
      // To make it look more like a roller, we can add a subtle noisy/faded edge
      // by drawing slightly wider strokes with low opacity behind it, but simple solid lines
      // look very clean and authentic for wide rollers.
    }

    private animate() {
      if (!this.isVisible) return;
      this.rafId = requestAnimationFrame(this.animate.bind(this));
      
      const now = performance.now();
      const elapsed = now - this.startTime;
      const globalProgress = elapsed / this.animationDuration;

      // Clear the canvas every frame before redrawing the growing strokes
      this.ctx.clearRect(0, 0, this.width, this.height);

      // Draw each stroke based on its individual timeline
      for (const stroke of this.strokes) {
        // Calculate the local progress for this specific stroke
        // e.g., if global = 0.5, delay = 0.2, duration = 0.4
        // localProgress = (0.5 - 0.2) / 0.4 = 0.3 / 0.4 = 0.75 (75% done)
        const localElapsed = globalProgress - stroke.delay;
        let localProgress = localElapsed / stroke.duration;
        
        if (localProgress > 0) {
          this.drawStroke(stroke, localProgress);
        }
      }

      // Stop animating if all strokes are completely drawn
      if (globalProgress >= 1.5) { // Adding buffer to ensure everything finishes
        cancelAnimationFrame(this.rafId);
        // Fill entire screen as a final safety measure to ensure no gaps
        this.ctx.fillStyle = this.paintColor;
        this.ctx.fillRect(0, 0, this.width, this.height);
      }
    }
  }

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    const canvasEl = document.getElementById('hero-canvas') as HTMLCanvasElement;
    if (canvasEl) {
      // Small delay on initialization to ensure page is visible
      setTimeout(() => {
        new PaintRollerCanvas(canvasEl);
      }, 500); 
    }
  } else {
    // If reduced motion, just show the fully painted teal background
    const canvasEl = document.getElementById('hero-canvas') as HTMLCanvasElement;
    if(canvasEl) canvasEl.style.display = 'none';
    const container = document.getElementById('canvas-container');
    if (container) {
      container.style.backgroundColor = '#4a8f96'; // Solid teal
    }
  }
</script>
