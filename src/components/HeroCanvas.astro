---
---
<div id="canvas-container" class="absolute inset-0 z-0 pointer-events-none overflow-hidden bg-charcoal">
  <canvas id="hero-canvas" class="w-full h-full" aria-hidden="true" aria-label="Animated paint texture, decorative"></canvas>
  <!-- Protective gradient to ensure text legibility -->
  <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/40 to-transparent pointer-events-none z-10"></div>
</div>

<script>
  import * as THREE from 'three';

  class PaintCanvas {
    private canvas: HTMLCanvasElement;
    private renderer: THREE.WebGLRenderer;
    private scene: THREE.Scene;
    private camera: THREE.PerspectiveCamera;
    private material: THREE.ShaderMaterial;
    private mesh: THREE.Mesh;
    private rafId: number = 0;
    private isVisible: boolean = true;
    private clock = new THREE.Clock();

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      this.init();
      this.bindEvents();
      this.animate();
    }

    private init() {
      try {
        this.renderer = new THREE.WebGLRenderer({ canvas: this.canvas, alpha: false, antialias: true });
        this.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      } catch (e) {
        console.warn("WebGL not supported, hiding canvas");
        if(this.canvas.parentElement) this.canvas.parentElement.style.display = 'none';
        return;
      }
      
      const width = window.innerWidth;
      const height = window.innerHeight;
      this.renderer.setSize(width, height);

      this.scene = new THREE.Scene();
      
      this.camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 100);
      this.camera.position.z = 3;

      // Load the texture
      const textureLoader = new THREE.TextureLoader();
      const texture = textureLoader.load('/images/interior-painting-contractor-syracuse-ny-gallagher-custom-finish.jpg');

      this.material = new THREE.ShaderMaterial({
        uniforms: {
          uTime: { value: 0 },
          uTexture: { value: texture },
          uImageAspect: { value: 1920 / 1080 }, // Original image aspect ratio
          uPlaneAspect: { value: width / height },
          uPaintColor: { value: new THREE.Color('#4a8f96') } // Teal color for the paint
        },
        vertexShader: `
          varying vec2 vUv;
          void main() {
            vUv = uv;
            gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
          }
        `,
        fragmentShader: `
          uniform float uTime;
          uniform sampler2D uTexture;
          uniform float uImageAspect;
          uniform float uPlaneAspect;
          uniform vec3 uPaintColor;
          
          varying vec2 vUv;

          // Classic Perlin noise, periodic version
          vec4 permute(vec4 x){return mod(((x*34.0)+1.0)*x, 289.0);}
          vec4 taylorInvSqrt(vec4 r){return 1.79284291400159 - 0.85373472095314 * r;}
          vec3 fade(vec3 t) {return t*t*t*(t*(t*6.0-15.0)+10.0);}

          float cnoise(vec3 P){
            vec3 Pi0 = floor(P);
            vec3 Pi1 = Pi0 + vec3(1.0);
            Pi0 = mod(Pi0, 289.0);
            Pi1 = mod(Pi1, 289.0);
            vec3 Pf0 = fract(P);
            vec3 Pf1 = Pf0 - vec3(1.0);
            vec4 ix = vec4(Pi0.x, Pi1.x, Pi0.x, Pi1.x);
            vec4 iy = vec4(Pi0.yy, Pi1.yy);
            vec4 iz0 = Pi0.zzzz;
            vec4 iz1 = Pi1.zzzz;

            vec4 ixy = permute(permute(ix) + iy);
            vec4 ixy0 = permute(ixy + iz0);
            vec4 ixy1 = permute(ixy + iz1);

            vec4 gx0 = ixy0 / 7.0;
            vec4 gy0 = fract(floor(gx0) / 7.0) - 0.5;
            gx0 = fract(gx0);
            vec4 gz0 = vec4(0.5) - abs(gx0) - abs(gy0);
            vec4 sz0 = step(gz0, vec4(0.0));
            gx0 -= sz0 * (step(0.0, gx0) - 0.5);
            gy0 -= sz0 * (step(0.0, gy0) - 0.5);

            vec4 gx1 = ixy1 / 7.0;
            vec4 gy1 = fract(floor(gx1) / 7.0) - 0.5;
            gx1 = fract(gx1);
            vec4 gz1 = vec4(0.5) - abs(gx1) - abs(gy1);
            vec4 sz1 = step(gz1, vec4(0.0));
            gx1 -= sz1 * (step(0.0, gx1) - 0.5);
            gy1 -= sz1 * (step(0.0, gy1) - 0.5);

            vec3 g000 = vec3(gx0.x,gy0.x,gz0.x);
            vec3 g100 = vec3(gx0.y,gy0.y,gz0.y);
            vec3 g010 = vec3(gx0.z,gy0.z,gz0.z);
            vec3 g110 = vec3(gx0.w,gy0.w,gz0.w);
            vec3 g001 = vec3(gx1.x,gy1.x,gz1.x);
            vec3 g101 = vec3(gx1.y,gy1.y,gz1.y);
            vec3 g011 = vec3(gx1.z,gy1.z,gz1.z);
            vec3 g111 = vec3(gx1.w,gy1.w,gz1.w);

            vec4 norm0 = taylorInvSqrt(vec4(dot(g000, g000), dot(g010, g010), dot(g100, g100), dot(g110, g110)));
            g000 *= norm0.x;
            g010 *= norm0.y;
            g100 *= norm0.z;
            g110 *= norm0.w;
            vec4 norm1 = taylorInvSqrt(vec4(dot(g001, g001), dot(g011, g011), dot(g101, g101), dot(g111, g111)));
            g001 *= norm1.x;
            g011 *= norm1.y;
            g101 *= norm1.z;
            g111 *= norm1.w;

            float n000 = dot(g000, Pf0);
            float n100 = dot(g100, vec3(Pf1.x, Pf0.yz));
            float n010 = dot(g010, vec3(Pf0.x, Pf1.y, Pf0.z));
            float n110 = dot(g110, vec3(Pf1.xy, Pf0.z));
            float n001 = dot(g001, vec3(Pf0.xy, Pf1.z));
            float n101 = dot(g101, vec3(Pf1.x, Pf0.y, Pf1.z));
            float n011 = dot(g011, vec3(Pf0.x, Pf1.yz));
            float n111 = dot(g111, Pf1);

            vec3 fade_xyz = fade(Pf0);
            vec4 n_z = mix(vec4(n000, n100, n010, n110), vec4(n001, n101, n011, n111), fade_xyz.z);
            vec2 n_yz = mix(n_z.xy, n_z.zw, fade_xyz.y);
            float n_xyz = mix(n_yz.x, n_yz.y, fade_xyz.x); 
            return 2.2 * n_xyz;
          }

          void main() {
            // Background-cover logic for UVs
            vec2 uv = vUv;
            float scaleX = 1.0;
            float scaleY = 1.0;
            
            if (uPlaneAspect > uImageAspect) {
              scaleY = uImageAspect / uPlaneAspect;
              uv.y = (uv.y - 0.5) * scaleY + 0.5;
            } else {
              scaleX = uPlaneAspect / uImageAspect;
              uv.x = (uv.x - 0.5) * scaleX + 0.5;
            }

            vec4 texColor = texture2D(uTexture, uv);
            
            // Noise to simulate thick horizontal/diagonal paint strokes rolling over
            float strokeNoise = cnoise(vec3(vUv.x * 2.0, vUv.y * 10.0, 0.0)) * 0.5 + 0.5;
            float edgeNoise = cnoise(vec3(vUv.x * 10.0, vUv.y * 3.0, 1.0)) * 0.1;

            // Slowly fill screen with paint from top to bottom (or right to left)
            // Progress goes from 0 to something > 1
            float progress = uTime * 0.15; 
            
            // Mask determines what is paint and what is image
            // We'll roll the paint diagonally
            float spread = (1.0 - vUv.x) * 0.4 + (1.0 - vUv.y) * 0.6; 
            
            // Threshold based on progress + noise
            float paintMask = smoothstep(progress - 0.2, progress + 0.2, spread + strokeNoise * 0.3 + edgeNoise);
            
            // The paint layer (teal color) plus some subtle noise for texture
            vec3 paintLayer = uPaintColor * (0.9 + strokeNoise * 0.2);

            // Mix the image and the paint layer based on the mask
            // When paintMask is 0, we see paint. When paintMask is 1, we see the image.
            vec3 finalColor = mix(paintLayer, texColor.rgb, clamp(paintMask, 0.0, 1.0));

            // Reduce overall brightness slightly if we are looking at the image to ensure text pops
            vec3 dimmedTex = texColor.rgb * 0.6;
            finalColor = mix(paintLayer, dimmedTex, clamp(paintMask, 0.0, 1.0));

            gl_FragColor = vec4(finalColor, 1.0);
          }
        `
      });

      // Simple plane filling the viewport
      const geometry = new THREE.PlaneGeometry(10, 10);
      this.mesh = new THREE.Mesh(geometry, this.material);
      this.scene.add(this.mesh);
    }

    private bindEvents() {
      window.addEventListener('resize', this.onResize.bind(this));
      document.addEventListener('visibilitychange', this.onVisibilityChange.bind(this));
    }

    private onResize() {
      if(!this.renderer) return;
      const width = window.innerWidth;
      const height = window.innerHeight;
      this.renderer.setSize(width, height);
      this.camera.aspect = width / height;
      this.camera.updateProjectionMatrix();
      if(this.material) {
        this.material.uniforms.uPlaneAspect.value = width / height;
      }
    }

    private onVisibilityChange() {
      this.isVisible = !document.hidden;
      if (this.isVisible) {
        this.clock.start();
        this.animate();
      } else {
        cancelAnimationFrame(this.rafId);
        this.clock.stop();
      }
    }

    private animate() {
      if (!this.isVisible || !this.renderer) return;
      this.rafId = requestAnimationFrame(this.animate.bind(this));
      
      const delta = this.clock.getDelta();
      // Only increment time up to a certain point so it doesn't loop infinitely 
      // This stops the animation once the screen is fully painted teal
      if (this.material.uniforms.uTime.value < 12.0) {
        this.material.uniforms.uTime.value += delta;
      }

      this.renderer.render(this.scene, this.camera);
    }
  }

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    const canvasEl = document.getElementById('hero-canvas') as HTMLCanvasElement;
    if (canvasEl) {
      new PaintCanvas(canvasEl);
    }
  } else {
    // If reduced motion, just show the background image
    const container = document.getElementById('canvas-container');
    if (container) {
      container.innerHTML = '<img src="/images/interior-painting-contractor-syracuse-ny-gallagher-custom-finish.jpg" alt="Interior painting contractor" class="w-full h-full object-cover opacity-60" />';
    }
  }
</script>
