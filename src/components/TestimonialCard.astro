---
export interface Props {
  name: string;
  city: string;
  projectType: string;
  review: string;
}

const { name, city, projectType, review } = Astro.props;
---
<div class="bg-white text-charcoal p-8 shadow-sm border border-gray-100 flex flex-col h-full rounded-sm hover:-translate-y-1 transition-transform duration-300">
  <div class="flex items-center gap-1 mb-4 text-brass">
    <!-- 5 Stars -->
    {Array.from({ length: 5 }).map(() => (
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>
  
  <blockquote class="text-gray-700 italic flex-grow mb-6 leading-relaxed">
    "{review}"
  </blockquote>
  
  <div class="mt-auto">
    <p class="font-heading font-bold text-lg">{name}</p>
    <p class="text-base text-gray-500 font-medium">{city} &middot; {projectType}</p>
  </div>
</div>
