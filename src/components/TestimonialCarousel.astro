---
import TestimonialCard from './TestimonialCard.astro';

const { testimonials = [] } = Astro.props;
---

<div class="testimonial-carousel relative w-full overflow-hidden min-h-[400px]">
  <!-- Slides container -->
  <div class="relative w-full h-full flex items-center justify-center">
    {testimonials.map((t: any, index: number) => (
      <div 
        class="carousel-slide absolute inset-0 transition-opacity duration-1000 ease-in-out flex items-center justify-center p-4" 
        data-index={index} 
        style={`opacity: ${index === 0 ? 1 : 0}; pointer-events: ${index === 0 ? 'auto' : 'none'}; z-index: ${index === 0 ? 10 : 0};`}
      >
        <div class="max-w-2xl w-full">
          <TestimonialCard {...t} />
        </div>
      </div>
    ))}
  </div>
  
  <!-- Dots container -->
  <div class="absolute bottom-4 left-0 right-0 flex justify-center gap-2 z-20">
    {testimonials.map((_: any, index: number) => (
      <button 
        class={`carousel-dot w-3 h-3 rounded-full bg-brass transition-opacity hover:opacity-100 focus-visible:outline-charcoal ${index === 0 ? 'opacity-100' : 'opacity-50'}`} 
        aria-label={`Go to slide ${index + 1}`}
        data-index={index}
      ></button>
    ))}
  </div>
</div>

<script>
  class Carousel {
    element: HTMLElement;
    slides: NodeListOf<HTMLElement>;
    dots: NodeListOf<HTMLElement>;
    currentIndex: number = 0;
    intervalId: number | null = null;
    
    constructor(element: HTMLElement) {
      this.element = element;
      this.slides = this.element.querySelectorAll('.carousel-slide');
      this.dots = this.element.querySelectorAll('.carousel-dot');
      
      if(this.slides.length <= 1) return;
      
      this.init();
    }
    
    init() {
      // Bind click events on dots
      this.dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          this.goToSlide(index);
          this.resetInterval();
        });
      });
      
      this.startInterval();
    }
    
    startInterval() {
      this.intervalId = window.setInterval(() => this.nextSlide(), 6000);
    }
    
    resetInterval() {
      if (this.intervalId !== null) {
        window.clearInterval(this.intervalId);
      }
      this.startInterval();
    }
    
    nextSlide() {
      let nextIndex = (this.currentIndex + 1) % this.slides.length;
      this.goToSlide(nextIndex);
    }
    
    goToSlide(index: number) {
      if (index === this.currentIndex) return;
      
      // Hide current
      const currentSlide = this.slides[this.currentIndex];
      currentSlide.style.opacity = '0';
      currentSlide.style.pointerEvents = 'none';
      currentSlide.style.zIndex = '0';
      
      if (this.dots[this.currentIndex]) {
        this.dots[this.currentIndex].classList.replace('opacity-100', 'opacity-50');
      }
      
      // Show next
      const nextSlide = this.slides[index];
      nextSlide.style.opacity = '1';
      nextSlide.style.pointerEvents = 'auto';
      nextSlide.style.zIndex = '10';
      
      if (this.dots[index]) {
        this.dots[index].classList.replace('opacity-50', 'opacity-100');
      }
      
      this.currentIndex = index;
    }
  }

  // Initialize all carousels on the page
  document.querySelectorAll('.testimonial-carousel').forEach(el => {
    new Carousel(el as HTMLElement);
  });
</script>
