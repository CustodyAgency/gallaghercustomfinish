---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustStrip from '../../components/TrustStrip.astro';

const title = "Millwork & Trim Finishing Syracuse NY | Gallagher Custom Finish";
const description = "Expert millwork and trim finishing for homes and historic buildings in Syracuse, Cortland, and Central New York. Doors, windows, crown, baseboards — factory-smooth results.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Millwork & Trim Finishing",
  "description": "Precision millwork and trim finishing for residential and commercial properties in Central New York. Covers doors, windows, crown molding, baseboards, and custom built-ins, with spray or brush application by site condition.",
  "url": "https://www.gallaghercustomfinish.com/syracuse-ny-millwork-trim-finishing/",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Gallagher Custom Finish",
    "telephone": "+13156077246",
    "url": "https://www.gallaghercustomfinish.com"
  },
  "areaServed": [
    {"@type": "City", "name": "Syracuse", "addressRegion": "NY"},
    {"@type": "City", "name": "Cortland", "addressRegion": "NY"},
    {"@type": "City", "name": "Cazenovia", "addressRegion": "NY"},
    {"@type": "AdministrativeArea", "name": "Central New York"}
  ],
  "serviceType": "Millwork & Trim Finishing"
};
---

<BaseLayout title={title} description={description} schema={schema}>

  <!-- Hero -->
  <section class="relative pt-32 pb-24 lg:pt-48 lg:pb-40 bg-charcoal text-cream overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/millwork-trim-finishing-contractor-syracuse-ny-gallagher.jpg"
        alt="Detail millwork and trim finishing by Gallagher Custom Finish, Syracuse NY"
        class="w-full h-full object-cover opacity-30"
        width="1400" height="800"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-charcoal/80 via-charcoal/60 to-charcoal"></div>
    </div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-brass font-bold uppercase tracking-widest text-sm mb-4">Millwork & Trim · Syracuse & Central New York</p>
      <h1 class="font-heading font-bold text-5xl md:text-6xl lg:text-7xl text-cream mb-6 drop-shadow-md leading-tight">
        The Details That Define<br class="hidden md:block"/> the Whole Room
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto mb-10 leading-relaxed font-medium">
        Trim is where people look. It's where brush marks, gaps, and uneven sheen are most visible. We treat every door, every casing, and every crown section as the most scrutinized surface in the room — because it usually is.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-painting-estimate-syracuse-cortland-ny/" class="inline-block bg-brass text-charcoal font-bold text-lg px-8 py-4 rounded hover:bg-cream transition-colors focus-visible:outline-cream">
          Get a Free Estimate
        </a>
        <a href="#trim-scope" class="inline-block border-2 border-cream text-cream font-bold text-lg px-8 py-4 rounded hover:bg-cream hover:text-charcoal transition-colors focus-visible:outline-cream">
          See Our Process
        </a>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-24 bg-cream text-charcoal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <h2 class="font-heading font-bold text-4xl mb-6">Why Trim Requires a Different Mindset</h2>
          <p class="text-lg text-gray-700 leading-relaxed mb-6">
            Walls are forgiving. The eye scans them without close inspection. Trim is different — it's a narrow, highly visible surface at eye level, hand height, and door height. Every brush mark, every lap line, every skip in coverage is obvious.
          </p>
          <p class="text-lg text-gray-700 leading-relaxed mb-6">
            That's why we don't rush trim. We sand between coats. We back-brush roller applications on flat casings. We spray when spraying is possible and appropriate. And we never count a trim coat done until it reads factory-smooth under a raking light.
          </p>
          <div class="bg-charcoal text-cream p-6 rounded-sm border-l-4 border-brass">
            <p class="font-bold text-brass mb-2 uppercase tracking-widest text-sm">The Hard Truth</p>
            <p class="text-gray-300 italic leading-relaxed">"Trim is where brush marks and holidays show up most. We don't rush it — and we don't hire painters who think trim is an afterthought."</p>
          </div>
        </div>

        <div id="trim-scope" class="space-y-8">
          <div class="bg-gray-50 border border-gray-200 p-8 rounded-sm">
            <h3 class="font-heading font-bold text-2xl mb-4">Standard Millwork Scope of Work</h3>
            <ul class="space-y-3 text-gray-700">
              {[
                "Full surface evaluation — existing finish condition, adhesion, sheen",
                "Light sanding or deglossingidentification of high-sheen or glossy existing finishes",
                "Fill nail holes, cracks, and joints with appropriate filler",
                "Spot-prime bare wood, repairs, and transitions",
                "Full prime coat on all new or re-stripped millwork",
                "Spray or brush application by product and site conditions",
                "Sand between coats on all enamel and semi-gloss work",
                "Minimum two finish coats to factory-smooth spec",
                "Back-brush or tip-off to eliminate lap marks and sags",
              ].map(item => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-brass flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-charcoal text-cream p-8 rounded-sm border border-gray-800">
            <h3 class="font-heading font-bold text-xl text-brass mb-3">What We Finish</h3>
            <ul class="grid grid-cols-2 gap-2 text-gray-300 text-base">
              {["Door slabs & casings", "Window trim & sills", "Crown molding", "Baseboards", "Built-ins & shelving", "Wainscoting", "Staircases & rails", "Fireplace surrounds"].map(s => (
                <li class="flex items-center gap-2"><span class="text-brass">—</span>{s}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Gallagher -->
  <section class="py-24 bg-charcoal text-cream border-t border-brass/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-4xl md:text-5xl text-center mb-16">75 Years of Finishing to the Last Detail</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            heading: "Historic Millwork Specialists",
            body: "Central New York is full of pre-war homes with original millwork that hasn't been touched right in decades. We know how to prep, prime, and finish old-growth pine and fir without destroying the profile."
          },
          {
            heading: "Spray-Capable Crews",
            body: "When conditions allow, spraying delivers the smoothest possible finish on enamel work. Our crews have the equipment and the training — and they know when brushing is actually the better call."
          },
          {
            heading: "The Same Finisher, Start to Finish",
            body: "Trim work is consistent only when the same person completes it. We don't rotate finishers through a job. One lead, one standard, one result."
          }
        ].map(card => (
          <div class="bg-gray-900 border border-gray-800 p-8 rounded-sm hover:border-brass/30 transition-colors">
            <h3 class="font-heading font-bold text-xl text-brass mb-4">{card.heading}</h3>
            <p class="text-gray-300 leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <TrustStrip />

  <!-- CTA -->
  <section class="py-24 bg-cream text-charcoal border-t border-gray-200 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading font-bold text-4xl mb-6">Ready for a Factory-Smooth Finish?</h2>
      <p class="text-lg text-gray-600 mb-10">Tell us what you're working with. We'll assess the scope and give you a line-item estimate — no vague numbers.</p>
      <a href="/free-painting-estimate-syracuse-cortland-ny/" class="inline-block bg-charcoal text-cream font-bold text-lg px-10 py-4 rounded hover:bg-brass hover:text-charcoal transition-colors focus-visible:outline-brass">
        Schedule a Free Estimate
      </a>
    </div>
  </section>

</BaseLayout>
