---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustStrip from '../../components/TrustStrip.astro';

const title = "Historic Restoration Painting Central New York | Gallagher Custom Finish";
const description = "EPA RRP-certified historic restoration painting in Syracuse, Cortland, and Central New York. Period-accurate color matching, lead-safe practices, preservation-grade coatings. 75 years of CNY experience.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Historic Restoration Painting",
  "description": "EPA RRP-certified lead-safe historic restoration painting for homes, churches, and landmark properties in Central New York. Period-correct color matching and preservation-grade coatings.",
  "url": "https://www.gallaghercustomfinish.com/central-new-york-historic-restoration-painting/",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Gallagher Custom Finish",
    "telephone": "+13156077246",
    "url": "https://www.gallaghercustomfinish.com"
  },
  "areaServed": [
    {"@type": "City", "name": "Syracuse", "addressRegion": "NY"},
    {"@type": "City", "name": "Cortland", "addressRegion": "NY"},
    {"@type": "City", "name": "Auburn", "addressRegion": "NY"},
    {"@type": "City", "name": "Cazenovia", "addressRegion": "NY"},
    {"@type": "AdministrativeArea", "name": "Central New York"}
  ],
  "serviceType": "Historic Restoration Painting",
  "hasCredential": [
    {"@type": "EducationalOccupationalCredential", "credentialCategory": "EPA RRP Certification"}
  ]
};
---

<BaseLayout title={title} description={description} schema={schema}>

  <!-- Hero -->
  <section class="relative pt-32 pb-24 lg:pt-48 lg:pb-40 bg-charcoal text-cream overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/historic-restoration-painting-contractor-central-new-york-gallagher.jpg"
        alt="Historic building restoration painting by Gallagher Custom Finish, Central New York"
        class="w-full h-full object-cover opacity-30"
        width="1400" height="800"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-charcoal/80 via-charcoal/60 to-charcoal"></div>
    </div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-brass font-bold uppercase tracking-widest text-sm mb-4">Historic Restoration · Central New York</p>
      <h1 class="font-heading font-bold text-5xl md:text-6xl lg:text-7xl text-cream mb-6 drop-shadow-md leading-tight">
        Preserving Central New York's<br class="hidden md:block"/> Built Heritage
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto mb-10 leading-relaxed font-medium">
        Historic properties in CNY demand certification most contractors don't hold, techniques most painters were never taught, and a respect for the structure that comes from 75 years of working in these buildings.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-painting-estimate-syracuse-cortland-ny/" class="inline-block bg-brass text-charcoal font-bold text-lg px-8 py-4 rounded hover:bg-cream transition-colors focus-visible:outline-cream">
          Get a Free Estimate
        </a>
        <a href="#historic-scope" class="inline-block border-2 border-cream text-cream font-bold text-lg px-8 py-4 rounded hover:bg-cream hover:text-charcoal transition-colors focus-visible:outline-cream">
          Our Credentials
        </a>
      </div>
    </div>
  </section>

  <!-- What Makes This Different -->
  <section class="py-24 bg-cream text-charcoal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <h2 class="font-heading font-bold text-4xl mb-6">Historic Work Requires Credentials Most Contractors Don't Hold</h2>
          <p class="text-lg text-gray-700 leading-relaxed mb-6">
            Any residential building in Central New York built before 1978 may contain lead-based paint. Federal law — the EPA's RRP Rule — requires that contractors working on those surfaces be certified in Lead-Safe Work Practices. It is not optional, and violations carry significant fines.
          </p>
          <p class="text-lg text-gray-700 leading-relaxed mb-6">
            Gallagher Custom Finish is EPA RRP certified. Our crews are trained in lead-safe disturbance practices, containment, and disposal. When we work on a pre-1978 home or building, we do it correctly — for your protection and ours.
          </p>
          <div class="bg-charcoal text-cream p-6 rounded-sm border-l-4 border-brass mb-8">
            <p class="font-bold text-brass mb-2 uppercase tracking-widest text-sm">Federal Law</p>
            <p class="text-gray-300 italic leading-relaxed">"Lead-safe practices are federal law, not optional. Before you hire anyone for pre-1978 restoration work, ask for their RRP certification. If they hesitate, that's your answer."</p>
          </div>

          <h3 class="font-heading font-bold text-2xl mb-4">Period-Accurate Color Matching</h3>
          <p class="text-gray-700 leading-relaxed">
            Historic property owners and preservation boards often require documentation of period-correct color schemes. We research archived references, match to historical paint specifications, and can provide written color documentation for landmark compliance submissions.
          </p>
        </div>

        <div id="historic-scope" class="space-y-8">
          <div class="bg-gray-50 border border-gray-200 p-8 rounded-sm">
            <h3 class="font-heading font-bold text-2xl mb-4">Historic Restoration Scope of Work</h3>
            <ul class="space-y-3 text-gray-700">
              {[
                "Pre-project lead paint testing and assessment",
                "EPA RRP-compliant containment setup for all disturbed areas",
                "Lead-safe paint disturbance, scraping, and removal",
                "Proper disposal in compliance with state and federal regulations",
                "Surface repair using period-appropriate techniques",
                "Linseed oil or penetrating primer on original wood substrates",
                "Preservation-grade topcoats — breathable and compatible with historic materials",
                "Period-accurate color matching from archived references",
                "Written documentation for landmark or preservation board review",
              ].map(item => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-brass flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-charcoal text-cream p-8 rounded-sm border border-gray-800">
            <h3 class="font-heading font-bold text-xl text-brass mb-3">Properties We Restore</h3>
            <ul class="space-y-2 text-gray-300 text-base">
              {[
                "Pre-war residential homes",
                "Victorian and Craftsman properties",
                "Historic churches and civic buildings",
                "Registered landmark structures",
                "Commercial buildings on historic registries",
                "Estate properties and carriage houses",
              ].map(s => (
                <li class="flex items-center gap-2"><span class="text-brass">—</span>{s}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Gallagher -->
  <section class="py-24 bg-charcoal text-cream border-t border-brass/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-bold text-4xl md:text-5xl text-center mb-16">75 Years Working in CNY Historic Structures</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            heading: "EPA RRP Certified",
            body: "Not every contractor carries this. We do. It means our crews are trained to work safely on pre-1978 properties and can document compliance for inspections, permits, and preservation boards."
          },
          {
            heading: "We've Seen These Buildings",
            body: "Three generations of Gallaghers have worked in CNY's Victorians, Craftsmans, brick colonials, and post-war cape cods. We know what the materials are, how they behave, and what they need."
          },
          {
            heading: "Preservation Board Experience",
            body: "We've worked on landmark properties requiring board approval. We understand the documentation, the color standards, and the level of care that gets a preservation project accepted on first submission."
          }
        ].map(card => (
          <div class="bg-gray-900 border border-gray-800 p-8 rounded-sm hover:border-brass/30 transition-colors">
            <h3 class="font-heading font-bold text-xl text-brass mb-4">{card.heading}</h3>
            <p class="text-gray-300 leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <TrustStrip />

  <!-- CTA -->
  <section class="py-24 bg-cream text-charcoal border-t border-gray-200 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading font-bold text-4xl mb-6">Working on a Historic Property?</h2>
      <p class="text-lg text-gray-600 mb-10">Start with a walk-through assessment. We'll identify the scope, the lead risk, the preservation requirements, and give you a clear picture of what the work involves before any commitment.</p>
      <a href="/free-painting-estimate-syracuse-cortland-ny/" class="inline-block bg-charcoal text-cream font-bold text-lg px-10 py-4 rounded hover:bg-brass hover:text-charcoal transition-colors focus-visible:outline-brass">
        Schedule a Free Assessment
      </a>
    </div>
  </section>

</BaseLayout>
