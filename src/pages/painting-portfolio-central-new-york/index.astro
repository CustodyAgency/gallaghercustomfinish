---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PortfolioCard from '../../components/PortfolioCard.astro';
import TrustStrip from '../../components/TrustStrip.astro';

const projects = [
  {
    imagePath: "/images/portfolio-victorian-brownstone-interior-restoration-syracuse-ny.jpg",
    title: "Victorian Brownstone Restoration",
    category: "Historic Interior",
    description: "Extensive plaster repair and period-accurate color matching for a historic Syracuse brownstone. Trim was meticulously prepped and top-coated with premium self-leveling enamel.",
    swatchColor: "#6A5D55" // Warm Taupe
  },
  {
    imagePath: "/images/portfolio-farmhouse-exterior-painting-central-new-york.jpg",
    title: "Central NY Farmhouse Exterior",
    category: "Residential Exterior",
    description: "Full exterior scrape, conditioning, and paint. Specialized sealants used on all siding joints and custom milled trim. Included a 10-year written warranty.",
    swatchColor: "#E2DFC8" // Vintage Cream
  },
  {
    imagePath: "/images/portfolio-historic-church-millwork-restoration-cortland-ny.jpg",
    title: "Cortland Church Millwork",
    category: "Commercial Restoration",
    description: "EPA RRP-compliant lead abatement and detailed restoration of 19th-century church millwork. Custom stain matching applied to heavily degraded sanctuary woodwork.",
    swatchColor: "#4B3621" // Dark Walnut
  },
  {
    imagePath: "/images/portfolio-kitchen-cabinet-refinishing-gallagher-custom-finish.jpg",
    title: "Custom Cabinet Refinishing",
    category: "Cabinets & Millwork",
    description: "Complete off-site and on-site spray finishing of existing kitchen cabinetry. Converted outdated oak boxes to a factory-smooth, highly durable modern finish.",
    swatchColor: "#2F4F4F" // Dark Slate Gray
  },
  {
    imagePath: "/images/portfolio-commercial-office-interior-painting-syracuse-ny.jpg",
    title: "Syracuse Tech Office",
    category: "Commercial Interior",
    description: "High-durability scuff-resistant coatings applied to all common areas and hallways. Work completed overnight and on weekends to ensure zero operational downtime for the client.",
    swatchColor: "#335165" // Steel Blue
  },
  {
    imagePath: "/images/portfolio-garage-epoxy-floor-coating-springfield-ny.jpg",
    title: "Springfield Garage Epoxy",
    category: "Floor Coatings",
    description: "Diamond-grind floor prep followed by a multi-part industrial epoxy coating system. Features high-traction vinyl flake broadcast and polyaspartic clear coat for chemical resistance.",
    swatchColor: "#A9A9A9" // Industrial Gray
  },
  {
    imagePath: "/images/portfolio-law-office-interior-paint-finish-cortland-ny.jpg",
    title: "Cortland Law Office",
    category: "Commercial Interior",
    description: "Premium low-VOC paints used throughout executive offices and conference rooms. Detailed cut-in work around extensive custom wainscoting and crown molding.",
    swatchColor: "#5C6A63" // Sage Gray
  },
  {
    imagePath: "/images/portfolio-multi-family-apartment-exterior-painting-syracuse.jpg",
    title: "Multi-Family Exterior Complex",
    category: "Commercial Exterior",
    description: "High-volume exterior painting of a 4-building apartment complex. Handled specialized boom-lift operations and strict timeline coordination with property management.",
    swatchColor: "#8D9289" // Weathered Green
  },
  {
    imagePath: "/images/portfolio-school-hallway-commercial-painting-central-ny.jpg",
    title: "Central NY School District",
    category: "Institutional",
    description: "Heavy-duty commercial wallcoverings and extreme-wear epoxy paints applied to high-traffic primary school corridors. Strict adherence to state facility safety standards.",
    swatchColor: "#DBCBA0" // Classic Schoolhouse Gold
  }
];

const title = "Painting Portfolio | Syracuse & Central NY | Gallagher Custom Finish";
const description = "View our recent residential and commercial painting, staining, and cabinet refinishing projects across Syracuse, Cortland, and Central New York.";
---

<BaseLayout title={title} description={description}>

  <!-- Hero Section -->
  <section class="pt-32 pb-16 lg:pt-40 lg:pb-20 bg-charcoal text-cream border-b border-brass/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center">
      <h1 class="font-heading font-bold text-5xl md:text-6xl text-brass mb-4 drop-shadow-sm">Select Projects</h1>
      <p class="text-xl text-gray-300 max-w-2xl font-medium">
        A gallery of our recent interior, exterior, and custom finish work across Central New York.
      </p>
      <div class="w-16 h-1 bg-brass mt-8"></div>
    </div>
  </section>

  <!-- Portfolio Grid -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-1 lg:gap-2">
        {projects.map((project, index) => (
          <PortfolioCard {...project} index={index} />
        ))}
      </div>
    </div>
  </section>

  <TrustStrip />

  <!-- Slideshow Overlay -->
  <div id="slideshow-overlay" class="fixed inset-0 z-[9999] bg-charcoal/95 backdrop-blur-md hidden flex flex-col items-center justify-start opacity-0 transition-opacity duration-300 px-4 md:px-12 pt-24 pb-8 overflow-y-auto">
    
    <button id="slideshow-close" class="absolute top-4 right-4 md:top-8 md:right-8 text-cream hover:text-brass transition-colors w-12 h-12 flex items-center justify-center focus-visible:outline-brass z-[200] cursor-pointer" aria-label="Close slideshow">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 block pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    
    <button id="slideshow-prev" class="absolute left-2 md:left-8 top-1/2 -translate-y-1/2 text-cream hover:text-brass transition-colors w-12 h-16 md:w-16 md:h-24 flex items-center justify-center focus-visible:outline-brass z-20" aria-label="Previous image">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 md:h-16 md:w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <button id="slideshow-next" class="absolute right-2 md:right-8 top-1/2 -translate-y-1/2 text-cream hover:text-brass transition-colors w-12 h-16 md:w-16 md:h-24 flex items-center justify-center focus-visible:outline-brass z-20" aria-label="Next image">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 md:h-16 md:w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <div class="relative w-full max-w-7xl flex flex-col items-center justify-center gap-6 mt-8 md:mt-0">
      <img id="slideshow-img" src="" alt="Portfolio full screen view" class="w-auto h-[50vh] md:h-[65vh] object-contain shadow-2xl transition-opacity duration-300 border-2 border-brass/20 bg-charcoal" />

      <!-- Bottom Content Bar -->
      <div class="w-full max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 bg-charcoal-light/50 p-6 rounded-xl border border-white/5">
        <div class="text-center md:text-left flex-1">
          <h3 id="slideshow-title" class="font-heading font-bold text-2xl md:text-3xl text-brass mb-2"></h3>
          <p id="slideshow-desc" class="text-cream text-base md:text-lg font-body leading-relaxed"></p>
        </div>
        <div class="shrink-0 flex items-center">
          <a href="tel:3156077246" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-charcoal bg-brass hover:bg-cream transition-colors shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            CALL 315-607-PAINT
          </a>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ projects }}>
    const overlay = document.getElementById('slideshow-overlay');
    const imgElement = document.getElementById('slideshow-img');
    const titleElement = document.getElementById('slideshow-title');
    const descElement = document.getElementById('slideshow-desc');
    const closeBtn = document.getElementById('slideshow-close');
    const prevBtn = document.getElementById('slideshow-prev');
    const nextBtn = document.getElementById('slideshow-next');
    
    let currentIndex = 0;
    
    function showSlide(index) {
      if (index < 0) index = projects.length - 1;
      if (index >= projects.length) index = 0;
      currentIndex = index;
      
      const project = projects[currentIndex];
      
      imgElement.style.opacity = '0';
      setTimeout(() => {
        imgElement.src = project.imagePath;
        imgElement.alt = project.title;
        titleElement.textContent = project.title;
        descElement.textContent = project.description;
        imgElement.style.opacity = '1';
      }, 150);
    }

    function openSlideshow(index) {
      showSlide(index);
      if (overlay) {
        overlay.classList.remove('hidden');
        setTimeout(() => overlay.classList.remove('opacity-0'), 10);
        document.body.style.overflow = 'hidden';
      }
    }

    function closeSlideshow() {
      if (overlay) {
        overlay.classList.add('opacity-0');
        setTimeout(() => {
          overlay.classList.add('hidden');
          document.body.style.overflow = '';
        }, 300);
      }
    }

    const triggers = document.querySelectorAll('.js-slideshow-trigger');
    triggers.forEach(trigger => {
      trigger.addEventListener('click', (e) => {
        const index = parseInt(trigger.getAttribute('data-index') || '0');
        openSlideshow(index);
      });
      trigger.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          const index = parseInt(trigger.getAttribute('data-index') || '0');
          openSlideshow(index);
        }
      });
    });

    closeBtn?.addEventListener('click', closeSlideshow);
    prevBtn?.addEventListener('click', () => showSlide(currentIndex - 1));
    nextBtn?.addEventListener('click', () => showSlide(currentIndex + 1));

    overlay?.addEventListener('click', (e) => {
      // Don't close if they click the image, the bottom bar, or its children
      const isContentClick = e.target.closest('#slideshow-img') || e.target.closest('.w-full.max-w-5xl');
      const isButton = e.target.closest('button');
      
      if (!isContentClick && !isButton && e.target.tagName !== 'A') {
        closeSlideshow();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (overlay && !overlay.classList.contains('hidden')) {
        if (e.key === 'Escape') closeSlideshow();
        if (e.key === 'ArrowLeft') showSlide(currentIndex - 1);
        if (e.key === 'ArrowRight') showSlide(currentIndex + 1);
      }
    });
  </script>

</BaseLayout>
