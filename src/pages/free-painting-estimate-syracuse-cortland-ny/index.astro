---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';

const title = "Free Painting Estimate | Syracuse & Cortland NY | Gallagher Custom Finish";
const description = "Request a free on-site estimate for painting, staining or finishing work in Syracuse, Cortland, Springfield and Central New York. 315-607-PAINT.";
---

<BaseLayout title={title} description={description}>

  <!-- Hero with Form Overlay -->
  <section class="relative pt-32 pb-48 lg:pt-48 lg:pb-64 bg-charcoal">
    <div class="absolute inset-0 z-0">
      <img src="/images/custom-finish-craftsman-detail-work-cortland-ny.jpg" alt="Detail finish work by Gallagher Custom Finish, Central New York painting contractor since 1950" class="w-full h-full object-cover opacity-30" width="1400" height="800" />
      <div class="absolute inset-0 bg-gradient-to-b from-charcoal/90 via-charcoal/80 to-charcoal"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading font-bold text-5xl md:text-6xl text-brass mb-6 drop-shadow-md">Get a Free Estimate &mdash; <br class="hidden md:block"/>Syracuse, Cortland &amp; Central New York</h1>
      <p class="text-xl md:text-2xl text-cream max-w-3xl mx-auto mb-6 leading-relaxed">
        We give you an honest assessment &mdash; including things that might change the scope. No surprises is the whole point.
      </p>
      <p class="text-brass font-bold uppercase tracking-widest text-base bg-charcoal/50 inline-block px-4 py-2 border border-brass/50 rounded-sm">
        We respond within one business day. Serving all of Central New York within 60 miles of Syracuse.
      </p>
    </div>
  </section>

  <!-- Form Section pulled up into hero -->
  <section class="relative z-20 -mt-32 md:-mt-48 pb-24 px-4 sm:px-6 lg:px-8">
    <LeadForm />
  </section>

  <!-- Reassurance & Business Info Block -->
  <section class="py-20 bg-cream text-charcoal border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <div class="space-y-12">
          <div>
            <h2 class="font-heading font-bold text-3xl mb-8 border-b-2 border-brass inline-block pb-2">The Gallagher Guarantee</h2>
          </div>
          <div class="flex flex-col gap-8">
            <div class="flex gap-4 items-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-brass flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <h3 class="font-bold text-xl mb-2">No obligation.</h3>
                <p class="text-gray-600 leading-relaxed">The estimate is free. We walk the job, tell you what we see, and give you a price.</p>
              </div>
            </div>
            
            <div class="flex gap-4 items-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-brass flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
              </svg>
              <div>
                <h3 class="font-bold text-xl mb-2">No pressure.</h3>
                <p class="text-gray-600 leading-relaxed">We don't chase jobs we didn't win. We'd rather earn the next call.</p>
              </div>
            </div>
            
            <div class="flex gap-4 items-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-brass flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <h3 class="font-bold text-xl mb-2">No surprises.</h3>
                <p class="text-gray-600 leading-relaxed">Scope changes are disclosed before we quote them. No mid-job change orders that weren't discussed.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-charcoal text-cream p-10 lg:p-12 rounded-sm shadow-xl relative overflow-hidden h-fit">
          <div class="absolute top-0 right-0 w-64 h-64 bg-brass opacity-5 rounded-full blur-3xl -mr-20 -mt-20 pointer-events-none"></div>
          
          <h2 class="font-heading font-bold text-3xl mb-8 text-brass">Contact Information</h2>
          
          <div class="space-y-6 text-lg relative z-10">
            <p class="flex items-center gap-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brass" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <a href="tel:3156077246" class="font-body font-bold text-xl tracking-wide hover:text-brass transition-colors focus-visible:outline-brass">315-607-PAINT</a>
            </p>
            <p class="flex items-center gap-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brass" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href="mailto:estimates@gallaghercustomfinish.com" class="hover:text-brass transition-colors max-w-full break-all focus-visible:outline-brass">estimates@gallaghercustomfinish.com</a>
            </p>
            
            <div class="pt-6 border-t border-gray-700">
              <p class="font-bold text-brass mb-2 uppercase tracking-wide text-base">Service Area</p>
              <p class="text-base text-gray-300 leading-relaxed">
                Syracuse &middot; Cortland &middot; Springfield &middot; Auburn &middot; Oswego &middot; Utica &middot; Rome &middot; Ithaca &middot; and within 60 miles of Central New York
              </p>
            </div>
            
            <div class="pt-6 border-t border-gray-700">
               <p class="font-bold text-brass mb-2 uppercase tracking-wide text-base">Hours</p>
               <p class="text-base text-gray-300">Monday–Friday 7:00am–5:00pm<br/>Saturday by appointment</p>
            </div>

            <div class="pt-6 flex flex-wrap gap-4 text-base font-bold text-gray-400 uppercase tracking-widest mt-4">
               <span>Licensed, Insured &amp; Bonded</span>
               <span>&bull;</span>
               <span>EPA RRP Certified</span>
               <span>&bull;</span>
               <span>No Subcontractors</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
